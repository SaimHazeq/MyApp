# Copy this file to .env and fill in real values before deploying.

ENVIRONMENT=development
DEBUG=true

# Generate a real secret with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_32_CHAR_MIN

CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=sqlite:///./storage/app.db

# Leave USE_CELERY=false to use the built-in thread-pool worker (no infra needed).
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

DEFAULT_RESOLUTION=1920x1080
DEFAULT_FPS=24
MAX_MOVIE_MINUTES=30

# --- Optional real AI providers ---
# Leave blank to use the built-in offline placeholder engines.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=

IMAGE_GEN_PROVIDER=placeholder   # placeholder | stability
VOICE_PROVIDER=placeholder       # placeholder | elevenlabs
MUSIC_PROVIDER=placeholder       # placeholder
